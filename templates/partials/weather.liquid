{% comment %}
  weather.liquid — header weather block (icon, temperature, feels-like, description).

  Required variables:
    weather            {description, temperature, feels_like, icon} — see dashboard.json "weather" key.
                       weather.icon is one of: "sun", "cloud", "rain", "partly-cloudy".

  Device-specific variables (parent template must pass these in):
    font_size_large    px size for the temperature figure (e.g. 34 on OG, 72 on X).
    font_size_tiny     px size for "Feels like" + description text.
    icon_size          px width/height of the weather icon square.
    padding            px gap between icon and text block, and around the block.

  Usage (python-liquid `render` tag — isolated scope, must pass every variable explicitly):
    {% render 'partials/weather', weather: weather, font_size_large: profile.font_size_large,
       font_size_tiny: profile.font_size_tiny, icon_size: 40, padding: profile.padding %}
{% endcomment %}
<div style="display:flex; align-items:center; gap:{{ padding }}px;">
  <div style="flex:0 0 auto; width:{{ icon_size }}px; height:{{ icon_size }}px;">
    {% if weather.icon == "sun" %}
      <svg viewBox="0 0 40 40" width="{{ icon_size }}" height="{{ icon_size }}" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="9" fill="none" stroke="#000000" stroke-width="2"/>
        <g stroke="#000000" stroke-width="2">
          <line x1="20" y1="1" x2="20" y2="7"/>
          <line x1="20" y1="33" x2="20" y2="39"/>
          <line x1="1" y1="20" x2="7" y2="20"/>
          <line x1="33" y1="20" x2="39" y2="20"/>
          <line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/>
          <line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/>
          <line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/>
          <line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/>
        </g>
      </svg>
    {% elsif weather.icon == "cloud" %}
      <svg viewBox="0 0 40 40" width="{{ icon_size }}" height="{{ icon_size }}" xmlns="http://www.w3.org/2000/svg">
        <g fill="none" stroke="#000000" stroke-width="2">
          <ellipse cx="14" cy="24" rx="9" ry="7"/>
          <ellipse cx="24" cy="22" rx="10" ry="8"/>
          <ellipse cx="20" cy="27" rx="12" ry="6"/>
        </g>
      </svg>
    {% elsif weather.icon == "rain" %}
      <svg viewBox="0 0 40 40" width="{{ icon_size }}" height="{{ icon_size }}" xmlns="http://www.w3.org/2000/svg">
        <g fill="none" stroke="#000000" stroke-width="2">
          <ellipse cx="14" cy="16" rx="8" ry="6"/>
          <ellipse cx="23" cy="14" rx="9" ry="7"/>
          <ellipse cx="19" cy="19" rx="11" ry="5"/>
        </g>
        <g stroke="#000000" stroke-width="2">
          <line x1="13" y1="28" x2="11" y2="36"/>
          <line x1="20" y1="28" x2="18" y2="36"/>
          <line x1="27" y1="28" x2="25" y2="36"/>
        </g>
      </svg>
    {% else %}
      {% comment %} partly-cloudy (default/fallback icon) {% endcomment %}
      <svg viewBox="0 0 40 40" width="{{ icon_size }}" height="{{ icon_size }}" xmlns="http://www.w3.org/2000/svg">
        <circle cx="26" cy="14" r="7" fill="none" stroke="#000000" stroke-width="2"/>
        <g stroke="#000000" stroke-width="2">
          <line x1="26" y1="2" x2="26" y2="5"/>
          <line x1="35" y1="14" x2="38" y2="14"/>
          <line x1="32.5" y1="7.5" x2="34.5" y2="5.5"/>
        </g>
        <g fill="#ffffff" stroke="#000000" stroke-width="2">
          <ellipse cx="13" cy="24" rx="9" ry="7"/>
          <ellipse cx="22" cy="22" rx="10" ry="8"/>
          <ellipse cx="18" cy="27" rx="12" ry="6"/>
        </g>
      </svg>
    {% endif %}
  </div>
  <div style="flex:1 1 auto; min-width:0;">
    <div style="font-weight:bold; font-size:{{ font_size_large }}px; line-height:1; color:#000000;">{{ weather.temperature }}&deg;C</div>
    <div style="font-size:{{ font_size_tiny }}px; color:#000000;">Feels like {{ weather.feels_like }}&deg;C</div>
    <div style="font-size:{{ font_size_tiny }}px; color:#000000; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ weather.description }}</div>
  </div>
</div>
