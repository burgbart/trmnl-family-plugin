{% comment %}
  calendar.liquid — "Upcoming" events section.

  Required variables:
    events              array of {title, start, end, all_day, attendees, calendar_id} — the
                        dashboard.json "events" key, in the order they should be displayed
                        (the parent is responsible for any pre-sorting).
    today               reference date as an ISO string "YYYY-MM-DD" (dashboard.json
                        meta.reference_date) — used to detect "Today" events.

  Device-specific variables (parent template must pass these in):
    max_events          max rows to render (DeviceProfile.max_events).
    font_size_medium    px size for the section title ("Upcoming").
    font_size_small     px size for each event row.
    line_height         px row height (DeviceProfile.line_height).
    padding             px internal padding.
    title               (optional) section title text, defaults to "Upcoming".

  Usage:
    {% render 'partials/calendar', events: events, today: meta.reference_date,
       max_events: profile.max_events, font_size_medium: profile.font_size_medium,
       font_size_small: profile.font_size_small, line_height: profile.line_height,
       padding: profile.padding %}
{% endcomment %}
<div style="padding:{{ padding }}px; height:100%; box-sizing:border-box; display:flex; flex-direction:column;">
  <div style="font-weight:bold; font-size:{{ font_size_medium }}px; color:#000000; margin-bottom:{{ padding }}px;">
    {{ title | default: "Upcoming" }}
  </div>
  <div style="flex:1 1 auto; overflow:hidden;">
    {% for event in events limit: max_events %}
      {% assign event_date = event.start | slice: 0, 10 %}
      <div style="display:flex; align-items:baseline; gap:{{ padding }}px; height:{{ line_height }}px; font-size:{{ font_size_small }}px; color:#000000;">
        <div style="flex:0 0 auto; min-width:16ch; white-space:nowrap;">
          {% if event.all_day %}
            {% if event_date == today %}
              Today &middot; All day
            {% elsif event.end and event.end != event.start %}
              {{ event.start | date: "%a %d %b" }}&ndash;{{ event.end | date: "%a %d %b" }}
            {% else %}
              {{ event.start | date: "%a %d %b" }} &middot; All day
            {% endif %}
          {% else %}
            {% if event_date == today %}
              Today {{ event.start | date: "%H:%M" }}
            {% else %}
              {{ event.start | date: "%a %d %b" }} {{ event.start | date: "%H:%M" }}
            {% endif %}
          {% endif %}
        </div>
        <div style="flex:1 1 auto; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
          {{ event.title }}
        </div>
      </div>
    {% else %}
      <div style="font-size:{{ font_size_small }}px; color:#000000;">No upcoming events</div>
    {% endfor %}
  </div>
</div>
