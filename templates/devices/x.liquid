<div class="page">
  {% comment %} Date header {% endcomment %}
  <div class="panel date-panel">
    <div style="display:flex; flex-direction:column; justify-content:center; height:100%; padding:24px;">
      <div class="day-name">{{ meta.reference_date | date: "%A" }}</div>
      <div class="date-line">{{ meta.reference_date | date: "%d %B" }}</div>
    </div>
    <div class="synced">Synced {{ meta.generated_at | date: "%H:%M %d/%m" }}</div>
  </div>

  {% comment %} Weather: current left + larger 3-day forecast right {% endcomment %}
  <div class="panel weather-panel">
    <div style="height:100%; padding:20px; box-sizing:border-box; display:flex; gap:16px;">
      {% comment %} Left: current weather (~25%) {% endcomment %}
      <div style="flex:0 0 25%; display:flex; flex-direction:column; justify-content:center;">
        <div style="display:flex; align-items:center; gap:16px; margin-bottom:8px;">
          <div style="width:64px; height:64px; flex:0 0 auto;">
            {% if weather.icon == "sun" %}{{ icon_sun_64 }}{% elsif weather.icon == "partly-cloudy" %}{{ icon_partly_64 }}{% elsif weather.icon == "cloud" %}{{ icon_cloud_64 }}{% elsif weather.icon == "rain-light" %}{{ icon_rain_light_64 }}{% elsif weather.icon == "rain" %}{{ icon_rain_64 }}{% elsif weather.icon == "rain-heavy" %}{{ icon_rain_heavy_64 }}{% elsif weather.icon == "thunder" %}{{ icon_thunder_64 }}{% elsif weather.icon == "snow" %}{{ icon_snow_64 }}{% else %}{{ icon_partly_64 }}{% endif %}
          </div>
          <div style="font-weight:bold; font-size:56px; line-height:1; color:#000000;">{{ weather.temperature }}&deg;C</div>
          <div style="display:flex; flex-direction:column; line-height:1; margin-left:8px;">
            <div style="font-size:16px; color:#555555; text-transform:lowercase;">real feel</div>
            <div style="font-size:22px; color:#000000;">{{ weather.feels_like }}&deg;C</div>
          </div>
        </div>
        <div style="font-size:22px; line-height:1.3; color:#000000; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ weather.description }}</div>
        {% if weather.alert %}
          <div style="font-size:22px; line-height:1.3; color:#000000; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-top:4px;">{{ weather.alert }}</div>
        {% endif %}
      </div>
      {% comment %} Right: larger 3-day forecast (~75%) {% endcomment %}
      <div style="flex:0 0 75%; display:flex; gap:16px;">
        {% for day in weather.forecast limit: 3 %}
          <div style="flex:1 1 0; min-width:0; text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center;">
            <div style="font-size:32px; line-height:1.2; color:#000000; white-space:nowrap;">{{ day.date | date: "%a" }}</div>
            <div style="width:80px; height:80px; margin:8px 0;">
              {% if day.icon == "sun" %}{{ icon_sun_80 }}{% elsif day.icon == "partly-cloudy" %}{{ icon_partly_80 }}{% elsif day.icon == "cloud" %}{{ icon_cloud_80 }}{% elsif day.icon == "rain-light" %}{{ icon_rain_light_80 }}{% elsif day.icon == "rain" %}{{ icon_rain_80 }}{% elsif day.icon == "rain-heavy" %}{{ icon_rain_heavy_80 }}{% elsif day.icon == "thunder" %}{{ icon_thunder_80 }}{% elsif day.icon == "snow" %}{{ icon_snow_80 }}{% else %}{{ icon_partly_80 }}{% endif %}
            </div>
            <div style="font-size:32px; line-height:1.2; color:#000000;">{{ day.temperature_high }}&deg;/{{ day.temperature_low }}&deg;</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% comment %} Upcoming events {% endcomment %}
  <div class="panel upcoming-panel">
    {% assign today = meta.reference_date %}
    <div style="padding:20px; height:100%; box-sizing:border-box; display:flex; flex-direction:column;">
      <div style="font-weight:bold; font-size:34px; color:#000000; margin-bottom:20px;">
        Upcoming
      </div>
      <div style="flex:1 1 auto; overflow:hidden;">
        {% if errors.events %}
        <div style="font-size:28px; font-weight:bold; color:#000000;">(!) Not loaded</div>
        <div style="font-size:28px; color:#000000; margin-top:10px;">{{ errors.events }}</div>
        {% else %}
        {% assign tomorrow = today | date: "%s" | plus: 86400 | date: "%Y-%m-%d" %}
        {% for event in events limit: 17 %}
          {% assign event_date = event.start | slice: 0, 10 %}
          {% assign is_today_or_tomorrow = false %}
          {% if event_date == today or event_date == tomorrow %}
            {% assign is_today_or_tomorrow = true %}
          {% endif %}
          <div style="display:flex; align-items:baseline; gap:20px; height:34px; font-size:28px; color:#000000;">
            <div style="flex:0 0 auto; min-width:16ch; white-space:nowrap;">
              {% if event.all_day %}
                {% if event_date == today %}
                  <span style="font-weight:bold;">Today</span> &middot; All day
                {% elsif event_date == tomorrow %}
                  <span style="font-weight:bold;">Tomorrow</span> &middot; All day
                {% elsif event.end and event.end != event.start %}
                  {{ event.start | date: "%a %d %b" }}&ndash;{{ event.end | date: "%a %d %b" }}
                {% else %}
                  {{ event.start | date: "%a %d %b" }} &middot; All day
                {% endif %}
              {% else %}
                {% if event_date == today %}
                  <span style="font-weight:bold;">Today</span> {{ event.start | date: "%H:%M" }}
                {% elsif event_date == tomorrow %}
                  <span style="font-weight:bold;">Tomorrow</span> {{ event.start | date: "%H:%M" }}
                {% else %}
                  {{ event.start | date: "%a %d %b" }} {{ event.start | date: "%H:%M" }}
                {% endif %}
              {% endif %}
            </div>
            <div style="flex:1 1 auto; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
              {{ event.title }}
            </div>
          </div>
        {% else %}
          <div style="font-size:28px; color:#000000;">No upcoming events</div>
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Tasks {% endcomment %}
  <div class="panel tasks-panel">
    {% assign today = meta.reference_date %}
    {% assign due_count = 0 %}
    {% for task in tasks %}
      {% unless task.done %}
        {% if task.due_date and task.due_date <= today %}
          {% assign due_count = due_count | plus: 1 %}
        {% endif %}
      {% endunless %}
    {% endfor %}
    <div style="padding:20px; height:100%; box-sizing:border-box; display:flex; flex-direction:column;">
      <div style="font-size:34px; color:#000000; margin-bottom:20px;">
        <span style="font-weight:bold;">Tasks</span>{% if due_count > 0 %} - {{ due_count }} due (!){% endif %}
      </div>
      <div style="flex:1 1 auto; overflow:hidden;">
        {% if errors.tasks %}
        <div style="font-size:28px; font-weight:bold; color:#000000;">(!) Not loaded</div>
        <div style="font-size:28px; color:#000000; margin-top:10px;">{{ errors.tasks }}</div>
        {% else %}
        {% for task in tasks limit: 17 %}
          {% assign is_due = false %}
          {% unless task.done %}
            {% if task.due_date and task.due_date <= today %}
              {% assign is_due = true %}
            {% endif %}
          {% endunless %}
          <div style="display:flex; align-items:center; gap:20px; height:34px;">
            <div style="flex:0 0 auto; width:24px; height:24px; border:2px solid #555555; box-sizing:border-box; position:relative;">
              {% if task.done %}
                <div style="position:absolute; top:1px; left:1px; right:1px; bottom:1px; border-top:2px solid #555555; transform:rotate(45deg); transform-origin:center;"></div>
              {% endif %}
            </div>
            <div style="flex:1 1 auto; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-size:28px; color:#000000; {% if is_due %}font-weight:bold;{% endif %}">
              {{ task.title }}{% if is_due %} (!){% endif %}
            </div>
          </div>
        {% else %}
          <div style="font-size:28px; color:#000000;">No tasks</div>
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Anniversaries: 3 equal columns — title + 2 columns of 4 {% endcomment %}
  <div class="panel anniv-panel">
    <div style="padding:24px; height:100%; box-sizing:border-box; display:flex; gap:24px;">
      <div style="flex:1 1 0;">
        <div style="font-weight:bold; font-size:34px; color:#000000; line-height:1;">Anniversaries</div>
      </div>
      {% if errors.birthdays %}
        <div style="flex:2 1 0;">
          <div style="font-size:30px; font-weight:bold; color:#000000;">(!) Not loaded</div>
          <div style="font-size:24px; color:#555555; margin-top:12px;">{{ errors.birthdays }}</div>
        </div>
      {% elsif birthdays.size == 0 %}
        <div style="flex:2 1 0;">
          <div style="font-size:30px; color:#555555;">No upcoming dates</div>
        </div>
      {% else %}
        {% assign tomorrow = meta.reference_date | date: "%s" | plus: 86400 | date: "%Y-%m-%d" %}
        <div style="flex:1 1 0; overflow:hidden;">
          {% for entry in birthdays limit: 4 %}
            <div style="display:flex; align-items:baseline; gap:10px; font-size:28px; line-height:34px; color:#000000; white-space:nowrap; overflow:hidden;">
              <span style="font-weight:bold; overflow:hidden; text-overflow:ellipsis;">{{ entry.name }}</span>
              <span style="flex:0 0 auto; color:#555555;">
                {% if entry.date == meta.reference_date %}
                  Today<span style="font-weight:bold; color:#000000;"> (!)</span>
                {% elsif entry.date == tomorrow %}
                  Tomorrow<span style="font-weight:bold; color:#000000;"> (!)</span>
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
        <div style="flex:1 1 0; overflow:hidden;">
          {% for entry in birthdays offset: 4 limit: 4 %}
            <div style="display:flex; align-items:baseline; gap:10px; font-size:28px; line-height:34px; color:#000000; white-space:nowrap; overflow:hidden;">
              <span style="font-weight:bold; overflow:hidden; text-overflow:ellipsis;">{{ entry.name }}</span>
              <span style="flex:0 0 auto; color:#555555;">
                {% if entry.date == meta.reference_date %}
                  Today<span style="font-weight:bold; color:#000000;"> (!)</span>
                {% elsif entry.date == tomorrow %}
                  Tomorrow<span style="font-weight:bold; color:#000000;"> (!)</span>
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
</body>
</html>
