{% capture icon_cloud_40 %}<svg viewBox="0 0 40 40" width="40" height="40" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#AAAAAA" stroke-width="2"><ellipse cx="14" cy="24" rx="9" ry="7"/><ellipse cx="24" cy="22" rx="10" ry="8"/><ellipse cx="20" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
