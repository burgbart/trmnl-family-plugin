{% comment %}
  devices/x.liquid — TRMNL X (1872x1404) default dashboard template.

  Default layout is the light mosaic design, scaled to the larger TRMNL X canvas:
    * Top-left light panel: day + date + synced time.
    * Top-right light panel: current weather + alert + 3-day forecast.
    * Middle-left light panel: Upcoming calendar events (maximized).
    * Middle-right light panel: Tasks (maximized).
    * Bottom full-width light panel: Anniversaries as a horizontal ticker.

  Uses only the four-level grayscale palette: #000000, #555555, #AAAAAA, #FFFFFF.
  #555555 is used only for borders and text, never as a panel fill.
  Top-level render context: meta, weather, events, tasks, birthdays, errors.
{% endcomment %}
<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>TRMNL X Dashboard — Creative Light</title>
<style>
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Regular.ttf") format("truetype");
    font-weight: normal;
  }
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Bold.ttf") format("truetype");
    font-weight: bold;
  }
  @font-face {
    font-family: "TRMNL21";
    src: url("../../assets/TRMNL21-Bold.ttf") format("truetype");
    font-weight: bold;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    width: 1872px;
    height: 1404px;
    background: #AAAAAA;
    font-family: "TRMNL16", Arial, Helvetica, sans-serif;
    color: #000000;
    overflow: hidden;
  }

  .page {
    position: relative;
    width: 1872px;
    height: 1404px;
    padding: 24px;
  }

  .panel {
    position: absolute;
    overflow: hidden;
    background: #FFFFFF;
    border: 2px solid #555555;
  }

  /* Top row: date (1/3) + weather (2/3) */
  .date-panel {
    left: 24px;
    top: 24px;
    width: 592px;
    height: 180px;
  }

  .weather-panel {
    left: 664px;
    top: 24px;
    width: 1184px;
    height: 180px;
  }

  /* Middle row */
  .upcoming-panel {
    left: 24px;
    top: 228px;
    width: 1098px;
    height: 678px;
  }

  .tasks-panel {
    left: 1146px;
    top: 228px;
    width: 702px;
    height: 678px;
  }

  /* Bottom row */
  .anniv-panel {
    left: 24px;
    top: 930px;
    width: 1824px;
    height: 450px;
  }

  .day-name {
    font-family: "TRMNL21", "TRMNL16", Arial, sans-serif;
    font-weight: bold;
    font-size: 64px;
    line-height: 1.05;
    color: #000000;
  }

  .date-line {
    font-size: 36px;
    line-height: 1.1;
    margin-top: 6px;
    color: #000000;
  }

  .synced {
    position: absolute;
    right: 24px;
    bottom: 12px;
    font-size: 24px;
    color: #555555;
  }
</style>
</head>
<body>

{% capture icon_sun_64 %}<svg viewBox="0 0 40 40" width="64" height="64" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="none" stroke="#555555" stroke-width="2"/><g stroke="#555555" stroke-width="2"><line x1="20" y1="1" x2="20" y2="7"/><line x1="20" y1="33" x2="20" y2="39"/><line x1="1" y1="20" x2="7" y2="20"/><line x1="33" y1="20" x2="39" y2="20"/><line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/><line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/><line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/><line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/></g></svg>{% endcapture %}
