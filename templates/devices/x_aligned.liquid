{% comment %}
  devices/x_aligned.liquid — TRMNL X (1872x1404) "aligned" layout.

  The header is constrained to the left column and aligns with the right edge
  of the Upcoming section. Tasks starts at the very top of the right column,
  making the two main columns equal in height.

  Uses the original simple weather partial in the header.
  Upcoming, Tasks and Anniversaries panels are tightened slightly so more
  rows fit the large panels.

  Layout:
    1. Header        (24,24)-(1085,204)    day/date (left) + weather (right)
    2. Upcoming      (24,228)-(1085,1380)  full left column
    3. Tasks         (1109,24)-(1848,865)  top-right, full-height start
    4. Anniversaries (1109,889)-(1848,1380) bottom-right

  Top-level context: meta, weather, events, tasks, birthdays, errors.
{% endcomment %}
<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>TRMNL X Dashboard — Aligned</title>
<style>
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Regular.ttf") format("truetype");
    font-weight: normal;
  }
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Bold.ttf") format("truetype");
    font-weight: bold;
  }
  @font-face {
    font-family: "TRMNL21";
    src: url("../../assets/TRMNL21-Bold.ttf") format("truetype");
    font-weight: bold;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    width: 1872px;
    height: 1404px;
    overflow: hidden;
    background: #AAAAAA;
    font-family: "TRMNL16", Arial, Helvetica, sans-serif;
    color: #000000;
  }
  .page {
    position: relative;
    width: 1872px;
    height: 1404px;
    background: #AAAAAA;
  }
  .box {
    position: absolute;
    background: #FFFFFF;
    border: 2px solid #555555;
    box-sizing: border-box;
    overflow: hidden;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 24px;
  }
  .header-daydate {
    font-family: "TRMNL21", "TRMNL16", Arial, sans-serif;
    font-weight: bold;
    font-size: 64px;
    color: #000000;
    line-height: 1.05;
  }
  .header-date {
    font-family: "TRMNL16", Arial, sans-serif;
    font-weight: normal;
    font-size: 36px;
    color: #000000;
    margin-top: 4px;
  }
  .header-weather {
    flex: 0 1 auto;
    min-width: 0;
    max-width: 520px;
  }
  .synced {
    position: absolute;
    right: 24px;
    bottom: 12px;
    font-size: 24px;
    color: #000000;
  }
</style>
</head>
<body>

<div class="page">

  {% comment %} 1. Header: constrained to left column, day/date + weather {% endcomment %}
  <div class="box" style="left:24px; top:24px; width:1061px; height:180px;">
    <div class="header-inner">
      <div>
        <div class="header-daydate">{{ meta.reference_date | date: "%A" }}</div>
        <div class="header-date">{{ meta.reference_date | date: "%d %B" }}</div>
      </div>
      <div class="header-weather">
        {% render 'partials/weather', weather: weather,
           font_size_large: 72, font_size_tiny: 24, icon_size: 90, padding: 24 %}
      </div>
    </div>
  </div>

  {% comment %} 2. Calendar / Upcoming — left column {% endcomment %}
  <div class="box" style="left:24px; top:228px; width:1061px; height:1152px;">
    {% render 'partials/calendar', events: events, error: errors.events, today: meta.reference_date,
       max_events: 24, font_size_medium: 36, font_size_small: 30,
       line_height: 42, padding: 24 %}
    <div class="synced">Synced {{ meta.generated_at | date: "%H:%M %d/%m" }}</div>
  </div>

  {% comment %} 3. Tasks — top-right, starts at the page top {% endcomment %}
  <div class="box" style="left:1109px; top:24px; width:739px; height:841px;">
    {% render 'partials/tasks', tasks: tasks, error: errors.tasks, today: meta.reference_date,
       max_tasks: 17, checkbox_size: 26, font_size_medium: 36, font_size_small: 30,
       line_height: 42, padding: 24 %}
  </div>

  {% comment %} 4. Anniversaries / Birthdays — bottom-right, remaining space {% endcomment %}
  <div class="box" style="left:1109px; top:889px; width:739px; height:491px;">
    {% render 'partials/birthdays', birthdays: birthdays, error: errors.birthdays, today: meta.reference_date,
       max_birthdays: 9, font_size_medium: 36, font_size_small: 30,
       line_height: 42, padding: 24 %}
  </div>

</div>
</body>
</html>
