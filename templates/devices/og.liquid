{% comment %}
  devices/og.liquid — TRMNL OG (800x480) default dashboard template.

  Default layout is the light mosaic design:
    * Top-left light panel: day + date + synced time.
    * Top-right light panel: current weather (with real feel) + alert + 3-day forecast grid.
    * Middle-left light panel: Upcoming calendar events.
    * Middle-right light panel: Tasks.
    * Bottom full-width light panel: Anniversaries as a horizontal ticker.

  Uses only the four-level grayscale palette: #000000, #555555, #AAAAAA, #FFFFFF.
  #555555 is used only for borders and text, never as a panel fill.
  Top-level render context: meta, weather, events, tasks, birthdays, errors.
{% endcomment %}
<style>
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Regular.ttf") format("truetype");
    font-weight: normal;
  }
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Bold.ttf") format("truetype");
    font-weight: bold;
  }
  @font-face {
    font-family: "TRMNL21";
    src: url("../../assets/TRMNL21-Bold.ttf") format("truetype");
    font-weight: bold;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    width: 800px;
    height: 480px;
    background: #AAAAAA;
    font-family: "TRMNL16", Arial, Helvetica, sans-serif;
    color: #000000;
    overflow: hidden;
  }

  .page {
    position: relative;
    width: 800px;
    height: 480px;
    padding: 10px;
  }

  .panel {
    position: absolute;
    overflow: hidden;
    background: #FFFFFF;
    border: 2px solid #555555;
  }

  /* Top row: date (1/3) + weather (2/3) */
  .date-panel {
    left: 10px;
    top: 10px;
    width: 253px;
    height: 100px;
  }

  .weather-panel {
    left: 273px;
    top: 10px;
    width: 517px;
    height: 100px;
  }

  /* Middle row: upcoming (left) + tasks (right) */
  .upcoming-panel {
    left: 10px;
    top: 120px;
    width: 500px;
    height: 250px;
  }

  .tasks-panel {
    left: 520px;
    top: 120px;
    width: 270px;
    height: 250px;
  }

  /* Bottom row: anniversaries ticker */
  .anniv-panel {
    left: 10px;
    top: 380px;
    width: 780px;
    height: 90px;
  }

  .day-name {
    font-family: "TRMNL21", "TRMNL16", Arial, sans-serif;
    font-weight: bold;
    font-size: 30px;
    line-height: 1.1;
    color: #000000;
  }

  .date-line {
    font-size: 18px;
    line-height: 1.1;
    margin-top: 4px;
    color: #000000;
  }

  .synced {
    position: absolute;
    right: 10px;
    bottom: 6px;
    font-size: 12px;
    color: #555555;
  }

  .date-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding: 10px;
  }

  /* Weather panel layout */
  .weather-layout {
    height: 100%;
    padding: 8px;
    box-sizing: border-box;
    display: flex;
    gap: 8px;
  }

  .weather-current {
    flex: 0 0 30%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .weather-current-main {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .weather-icon {
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
  }

  .weather-temperature {
    font-weight: bold;
    font-size: 26px;
    line-height: 1;
    color: #000000;
  }

  .weather-feels-like {
    display: flex;
    flex-direction: column;
    line-height: 1;
    margin-left: 4px;
  }

  .weather-feels-like-label {
    font-size: 11px;
    color: #555555;
    text-transform: lowercase;
  }

  .weather-feels-like-value {
    font-size: 15px;
    color: #000000;
  }

  .weather-description,
  .weather-alert {
    font-size: 14px;
    line-height: 1.2;
    color: #000000;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .weather-alert {
    margin-top: 2px;
  }

  .weather-forecast {
    flex: 0 0 70%;
    display: flex;
    gap: 8px;
  }

  .weather-forecast-day {
    flex: 1 1 0;
    min-width: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .weather-forecast-day-name,
  .weather-forecast-temp {
    font-size: 14px;
    line-height: 1.1;
    color: #000000;
    white-space: nowrap;
  }

  .weather-forecast-icon {
    width: 32px;
    height: 32px;
    margin: 4px 0;
  }
</style>

{% capture icon_sun_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="20" y1="1" x2="20" y2="7"/><line x1="20" y1="33" x2="20" y2="39"/><line x1="1" y1="20" x2="7" y2="20"/><line x1="33" y1="20" x2="39" y2="20"/><line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/><line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/><line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/><line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/></g></svg>{% endcapture %}
{% capture icon_cloud_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="24" rx="9" ry="7"/><ellipse cx="24" cy="22" rx="10" ry="8"/><ellipse cx="20" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_rain_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="16" rx="8" ry="6"/><ellipse cx="23" cy="14" rx="9" ry="7"/><ellipse cx="19" cy="19" rx="11" ry="5"/></g><g stroke="#000000" stroke-width="2"><line x1="13" y1="28" x2="11" y2="36"/><line x1="20" y1="28" x2="18" y2="36"/><line x1="27" y1="28" x2="25" y2="36"/></g></svg>{% endcapture %}
{% capture icon_partly_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><circle cx="26" cy="14" r="7" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="26" y1="2" x2="26" y2="5"/><line x1="35" y1="14" x2="38" y2="14"/><line x1="32.5" y1="7.5" x2="34.5" y2="5.5"/></g><g fill="#ffffff" stroke="#000000" stroke-width="2"><ellipse cx="13" cy="24" rx="9" ry="7"/><ellipse cx="22" cy="22" rx="10" ry="8"/><ellipse cx="18" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_sun_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="20" y1="1" x2="20" y2="7"/><line x1="20" y1="33" x2="20" y2="39"/><line x1="1" y1="20" x2="7" y2="20"/><line x1="33" y1="20" x2="39" y2="20"/><line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/><line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/><line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/><line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/></g></svg>{% endcapture %}
{% capture icon_cloud_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="24" rx="9" ry="7"/><ellipse cx="24" cy="22" rx="10" ry="8"/><ellipse cx="20" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_rain_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="16" rx="8" ry="6"/><ellipse cx="23" cy="14" rx="9" ry="7"/><ellipse cx="19" cy="19" rx="11" ry="5"/></g><g stroke="#000000" stroke-width="2"><line x1="13" y1="28" x2="11" y2="36"/><line x1="20" y1="28" x2="18" y2="36"/><line x1="27" y1="28" x2="25" y2="36"/></g></svg>{% endcapture %}
{% capture icon_partly_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><circle cx="26" cy="14" r="7" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="26" y1="2" x2="26" y2="5"/><line x1="35" y1="14" x2="38" y2="14"/><line x1="32.5" y1="7.5" x2="34.5" y2="5.5"/></g><g fill="#ffffff" stroke="#000000" stroke-width="2"><ellipse cx="13" cy="24" rx="9" ry="7"/><ellipse cx="22" cy="22" rx="10" ry="8"/><ellipse cx="18" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}

<div class="page">
  {% comment %} Date header {% endcomment %}
  <div class="panel date-panel">
    <div class="date-content">
      <div class="day-name">{{ meta.reference_date | date: "%A" }}</div>
      <div class="date-line">{{ meta.reference_date | date: "%d %B" }}</div>
    </div>
    <div class="synced">Synced {{ meta.generated_at | date: "%H:%M %d/%m" }}</div>
  </div>

  {% comment %} Weather: current left + 3-day forecast right {% endcomment %}
  <div class="panel weather-panel">
    <div class="weather-layout">
      {% comment %} Left: current weather (~30%) {% endcomment %}
      <div class="weather-current">
        <div class="weather-current-main">
          <div class="weather-icon">
            {% if weather.icon == "sun" %}{{ icon_sun_32 }}{% elsif weather.icon == "cloud" %}{{ icon_cloud_32 }}{% elsif weather.icon == "rain" %}{{ icon_rain_32 }}{% else %}{{ icon_partly_32 }}{% endif %}
          </div>
          <div class="weather-temperature">{{ weather.temperature }}&deg;C</div>
          <div class="weather-feels-like">
            <div class="weather-feels-like-label">real feel</div>
            <div class="weather-feels-like-value">{{ weather.feels_like }}&deg;C</div>
          </div>
        </div>
        <div class="weather-description">{{ weather.description }}</div>
        {% if weather.alert %}
          <div class="weather-alert">{{ weather.alert }}</div>
        {% endif %}
      </div>
      {% comment %} Right: 3-day forecast (~70%) {% endcomment %}
      <div class="weather-forecast">
        {% for day in weather.forecast limit: 3 %}
          <div class="weather-forecast-day">
            <div class="weather-forecast-day-name">{{ day.date | date: "%a" }}</div>
            <div class="weather-forecast-icon">
              {% if day.icon == "sun" %}{{ icon_sun_32 }}{% elsif day.icon == "cloud" %}{{ icon_cloud_32 }}{% elsif day.icon == "rain" %}{{ icon_rain_32 }}{% else %}{{ icon_partly_32 }}{% endif %}
            </div>
            <div class="weather-forecast-temp">{{ day.temperature_high }}&deg;/{{ day.temperature_low }}&deg;</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% comment %} Upcoming events {% endcomment %}
  <div class="panel upcoming-panel">
    <div style="padding:8px; height:100%; box-sizing:border-box; display:flex; flex-direction:column;">
      <div style="font-weight:bold; font-size:17px; color:#000000; margin-bottom:8px;">
        Upcoming
      </div>
      <div style="flex:1 1 auto; overflow:hidden;">
        {% if errors.events %}
        <div style="font-size:15px; font-weight:bold; color:#000000;">(!) Not loaded</div>
        <div style="font-size:15px; color:#000000; margin-top:4px;">{{ errors.events }}</div>
        {% else %}
        {% for event in events limit: 9 %}
          {% assign event_date = event.start | slice: 0, 10 %}
          <div style="display:flex; align-items:baseline; gap:8px; height:22px; font-size:15px; color:#000000;">
            <div style="flex:0 0 auto; min-width:16ch; white-space:nowrap;">
              {% if event.all_day %}
                {% if event_date == meta.reference_date %}
                  Today &middot; All day
                {% elsif event.end and event.end != event.start %}
                  {{ event.start | date: "%a %d %b" }}&ndash;{{ event.end | date: "%a %d %b" }}
                {% else %}
                  {{ event.start | date: "%a %d %b" }} &middot; All day
                {% endif %}
              {% else %}
                {% if event_date == meta.reference_date %}
                  Today {{ event.start | date: "%H:%M" }}
                {% else %}
                  {{ event.start | date: "%a %d %b" }} {{ event.start | date: "%H:%M" }}
                {% endif %}
              {% endif %}
            </div>
            <div style="flex:1 1 auto; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
              {{ event.title }}
            </div>
          </div>
        {% else %}
          <div style="font-size:15px; color:#000000;">No upcoming events</div>
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Tasks {% endcomment %}
  <div class="panel tasks-panel">
    {% assign due_count = 0 %}
    {% for task in tasks %}
      {% unless task.done %}
        {% if task.due_date and task.due_date <= meta.reference_date %}
          {% assign due_count = due_count | plus: 1 %}
        {% endif %}
      {% endunless %}
    {% endfor %}
    <div style="padding:8px; height:100%; box-sizing:border-box; display:flex; flex-direction:column;">
      <div style="font-size:17px; color:#000000; margin-bottom:8px;">
        <span style="font-weight:bold;">Tasks</span>{% if due_count > 0 %} - {{ due_count }} due (!){% endif %}
      </div>
      <div style="flex:1 1 auto; overflow:hidden;">
        {% if errors.tasks %}
        <div style="font-size:15px; font-weight:bold; color:#000000;">(!) Not loaded</div>
        <div style="font-size:15px; color:#000000; margin-top:4px;">{{ errors.tasks }}</div>
        {% else %}
        {% for task in tasks limit: 9 %}
          {% assign is_due = false %}
          {% unless task.done %}
            {% if task.due_date and task.due_date <= meta.reference_date %}
              {% assign is_due = true %}
            {% endif %}
          {% endunless %}
          <div style="display:flex; align-items:center; gap:8px; height:22px;">
            <div style="flex:0 0 auto; width:11px; height:11px; border:2px solid #555555; box-sizing:border-box; position:relative;">
              {% if task.done %}
                <div style="position:absolute; top:1px; left:1px; right:1px; bottom:1px; border-top:2px solid #555555; transform:rotate(45deg); transform-origin:center;"></div>
              {% endif %}
            </div>
            <div style="flex:1 1 auto; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-size:15px; color:#000000; {% if is_due %}font-weight:bold;{% endif %}">
              {{ task.title }}{% if is_due %} (!){% endif %}
            </div>
          </div>
        {% else %}
          <div style="font-size:15px; color:#000000;">No tasks</div>
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Anniversaries: 3 equal columns — title + 2 columns of 4 {% endcomment %}
  <div class="panel anniv-panel">
    <div style="padding:10px; height:100%; box-sizing:border-box; display:flex; gap:10px;">
      <div style="flex:1 1 0;">
        <div style="font-weight:bold; font-size:17px; color:#000000; line-height:1;">Anniversaries</div>
      </div>
      {% if errors.birthdays %}
        <div style="flex:2 1 0;">
          <div style="font-size:15px; font-weight:bold; color:#000000;">(!) Not loaded</div>
          <div style="font-size:13px; color:#555555; margin-top:4px;">{{ errors.birthdays }}</div>
        </div>
      {% elsif birthdays.size == 0 %}
        <div style="flex:2 1 0;">
          <div style="font-size:15px; color:#555555;">No upcoming dates</div>
        </div>
      {% else %}
        <div style="flex:1 1 0; overflow:hidden;">
          {% for entry in birthdays limit: 4 %}
            <div style="display:flex; align-items:baseline; gap:6px; font-size:13px; line-height:15px; color:#000000; white-space:nowrap; overflow:hidden;">
              <span style="font-weight:bold; overflow:hidden; text-overflow:ellipsis;">{{ entry.name }}</span>
              <span style="color:#555555; flex:0 0 auto;">
                {% if entry.date == meta.reference_date %}
                  Today!
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
        <div style="flex:1 1 0; overflow:hidden;">
          {% for entry in birthdays offset: 4 limit: 4 %}
            <div style="display:flex; align-items:baseline; gap:6px; font-size:13px; line-height:15px; color:#000000; white-space:nowrap; overflow:hidden;">
              <span style="font-weight:bold; overflow:hidden; text-overflow:ellipsis;">{{ entry.name }}</span>
              <span style="color:#555555; flex:0 0 auto;">
                {% if entry.date == meta.reference_date %}
                  Today!
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
