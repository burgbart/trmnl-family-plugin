{% comment %}
  devices/og.liquid — TRMNL OG (800x480) default dashboard template.

  Default layout is the light mosaic design:
    * Top-left light panel: day + date + synced time.
    * Top-right light panel: current weather (with real feel) + alert + 3-day forecast grid.
    * Middle-left light panel: Upcoming calendar events.
    * Middle-right light panel: Tasks.
    * Bottom full-width light panel: Anniversaries as a horizontal ticker.

  Uses only the four-level grayscale palette: #000000, #555555, #AAAAAA, #FFFFFF
  (TRMNL Framework tokens black / gray-30 / gray-55 / white — see
  https://trmnl.com/framework/docs/3.1/background). Pure black/white are safe
  as raw hex on any bit depth; the two mid grays (#555555, #AAAAAA) use the
  framework's bg--/text-- utility classes instead of inline hex so TRMNL's
  2-bit+ renderer treats them as solid palette stops rather than dithering an
  unrecognized color down to black/white. Panel/checkbox borders are still
  raw `border: Npx solid #555555` — the framework's border--h/v-{n} utility
  couples thickness and shade in a way that doesn't map onto a crisp 2px
  4-sided border, so it isn't used here.
  Top-level render context: meta, weather, events, tasks, birthdays, errors.
{% endcomment %}
<style>
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Regular.ttf") format("truetype");
    font-weight: normal;
  }
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Bold.ttf") format("truetype");
    font-weight: bold;
  }
  @font-face {
    font-family: "TRMNL21";
    src: url("../../assets/TRMNL21-Bold.ttf") format("truetype");
    font-weight: bold;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    width: 800px;
    height: 480px;
    font-family: "TRMNL16", Arial, Helvetica, sans-serif;
    color: #000000;
    overflow: hidden;
  }

  .page {
    position: relative;
    width: 800px;
    height: 480px;
    padding: 10px;
  }

  .panel {
    position: absolute;
    overflow: hidden;
    background: #FFFFFF;
    border: 2px solid #555555;
  }

  /* Top row: date (1/3) + weather (2/3) */
  .date-panel {
    left: 10px;
    top: 10px;
    width: 253px;
    height: 100px;
  }

  .weather-panel {
    left: 273px;
    top: 10px;
    width: 517px;
    height: 100px;
  }

  /* Middle row: upcoming (left) + tasks (right) */
  .upcoming-panel {
    left: 10px;
    top: 120px;
    width: 500px;
    height: 250px;
  }

  .tasks-panel {
    left: 520px;
    top: 120px;
    width: 270px;
    height: 250px;
  }

  /* Bottom row: anniversaries ticker */
  .anniv-panel {
    left: 10px;
    top: 380px;
    width: 780px;
    height: 90px;
  }

  .day-name {
    font-family: "TRMNL21", "TRMNL16", Arial, sans-serif;
    font-weight: bold;
    font-size: 30px;
    line-height: 1.1;
    color: #000000;
  }

  .date-line {
    font-size: 18px;
    line-height: 1.1;
    margin-top: 4px;
    color: #000000;
  }

  .synced {
    position: absolute;
    right: 10px;
    bottom: 6px;
    font-size: 12px;
  }

  .date-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    padding: 10px;
  }

  /* Weather panel layout */
  .weather-layout {
    height: 100%;
    padding: 8px;
    box-sizing: border-box;
    display: flex;
    gap: 8px;
  }

  .weather-current {
    flex: 0 0 40%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .weather-current-main {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .weather-icon {
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
  }

  .weather-temperature {
    font-weight: bold;
    font-size: 26px;
    line-height: 1;
    color: #000000;
  }

  .weather-feels-like {
    display: flex;
    flex-direction: column;
    line-height: 1;
    margin-left: 4px;
  }

  .weather-feels-like-label {
    font-size: 11px;
    text-transform: lowercase;
  }

  .weather-feels-like-value {
    font-size: 15px;
    color: #000000;
  }

  .weather-description,
  .weather-alert {
    font-size: 14px;
    line-height: 1.2;
    color: #000000;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .weather-alert {
    margin-top: 2px;
  }

  .weather-forecast {
    flex: 0 0 58%;
    display: flex;
    gap: 2px;
  }

  .weather-forecast-day {
    flex: 1 1 0;
    min-width: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .weather-forecast-day-name,
  .weather-forecast-temp {
    font-size: 11px;
    line-height: 1.1;
    color: #000000;
    white-space: nowrap;
  }

  .weather-forecast-icon {
    width: 22px;
    height: 22px;
    margin: 2px 0;
  }

  /* The captured icon SVGs carry hardcoded width="32" height="32"
     attributes (shared with .weather-icon at 32px); force them to fill
     this smaller container instead of overflowing it at their intrinsic
     size. */
  .weather-forecast-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Shared panel body: Upcoming + Tasks inner wrapper */
  .panel-body {
    padding: 8px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  .section-title {
    font-size: 17px;
    color: #000000;
    margin-bottom: 8px;
  }

  .section-title--bold {
    font-weight: bold;
  }

  .section-title-label {
    font-weight: bold;
  }

  .section-body {
    flex: 1 1 auto;
    overflow: hidden;
  }

  .error-title {
    font-size: 15px;
    font-weight: bold;
    color: #000000;
  }

  .error-detail {
    font-size: 15px;
    color: #000000;
    margin-top: 4px;
  }

  .error-detail-small {
    font-size: 13px;
    margin-top: 4px;
  }

  .empty-message {
    font-size: 15px;
    color: #000000;
  }

  /* Upcoming events */
  .event-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    height: 22px;
    font-size: 15px;
    color: #000000;
  }

  .event-time {
    flex: 0 0 auto;
    min-width: 16ch;
    white-space: nowrap;
  }

  .event-title {
    flex: 1 1 auto;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Tasks */
  .task-row {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 22px;
  }

  .task-checkbox {
    flex: 0 0 auto;
    width: 11px;
    height: 11px;
    border: 2px solid #555555;
    box-sizing: border-box;
    position: relative;
  }

  .task-checkbox-mark {
    position: absolute;
    top: 1px;
    left: 1px;
    right: 1px;
    bottom: 1px;
    border-top: 2px solid #555555;
    transform: rotate(45deg);
    transform-origin: center;
  }

  .task-title {
    flex: 1 1 auto;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 15px;
    color: #000000;
  }

  .task-title--due {
    font-weight: bold;
  }

  /* Anniversaries */
  .anniv-inner {
    padding: 10px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    gap: 10px;
  }

  .anniv-title-col {
    flex: 1 1 0;
  }

  .anniv-title {
    font-weight: bold;
    font-size: 17px;
    color: #000000;
    line-height: 1;
  }

  .anniv-status-col {
    flex: 2 1 0;
  }

  .anniv-col {
    flex: 1 1 0;
    overflow: hidden;
  }

  .anniv-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    font-size: 13px;
    line-height: 15px;
    color: #000000;
    white-space: nowrap;
    overflow: hidden;
  }

  .anniv-name {
    font-weight: bold;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .anniv-date {
    flex: 0 0 auto;
  }

  /* Local shim for TRMNL Framework's bg--/text-- utility classes (defined
     natively on TRMNL's platform, not by this stylesheet). Keeps
     export_preview.py's local preview visually accurate; harmless no-op
     duplication when TRMNL's own framework CSS is present. */
  .bg--gray-55 { background: #AAAAAA; }
  .text--gray-30 { color: #555555; }
</style>

{% capture icon_sun_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="#000000"/><g stroke="#000000" stroke-width="3" stroke-linecap="round"><line x1="20" y1="8" x2="20" y2="2"/><line x1="20" y1="32" x2="20" y2="38"/><line x1="32" y1="20" x2="38" y2="20"/><line x1="8" y1="20" x2="2" y2="20"/><line x1="28.49" y1="11.51" x2="32.73" y2="7.27"/><line x1="28.49" y1="28.49" x2="32.73" y2="32.73"/><line x1="11.51" y1="28.49" x2="7.27" y2="32.73"/><line x1="11.51" y1="11.51" x2="7.27" y2="7.27"/></g></svg>{% endcapture %}
{% capture icon_cloud_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><g transform="translate(-2.5,1)" fill="#555555"><rect x="6" y="20" width="28" height="12" rx="6" ry="6"/><circle cx="14" cy="19" r="8"/><circle cx="24" cy="16" r="10"/><circle cx="32" cy="21" r="7"/></g></svg>{% endcapture %}
{% capture icon_rain_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><g transform="translate(-1.5,0.5)"><g fill="#555555"><rect x="7" y="12" width="26" height="10" rx="5" ry="5"/><circle cx="14" cy="12" r="7"/><circle cx="23" cy="9" r="8"/><circle cx="30" cy="13" r="6"/></g><g fill="#000000"><polygon points="12,23 16,28 8,28"/><circle cx="12" cy="31" r="5"/><polygon points="20,26 24,31 16,31"/><circle cx="20" cy="34" r="4"/><polygon points="28,23 32,28 24,28"/><circle cx="28" cy="31" r="5"/></g></g></svg>{% endcapture %}
{% capture icon_partly_32 %}<svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg"><g transform="translate(-0.5,3.5)"><g fill="#AAAAAA"><rect x="2" y="23" width="24" height="10" rx="5" ry="5"/><circle cx="9" cy="22" r="6"/><circle cx="17" cy="19" r="8"/><circle cx="24" cy="23" r="5"/></g><circle cx="30" cy="11" r="6" fill="#000000"/><g stroke="#000000" stroke-width="3" stroke-linecap="round"><line x1="30" y1="3" x2="30" y2="0"/><line x1="34.5" y1="6.5" x2="36.5" y2="4.5"/><line x1="37" y1="11" x2="39" y2="11"/></g></g></svg>{% endcapture %}
{% capture icon_sun_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="#000000"/><g stroke="#000000" stroke-width="3" stroke-linecap="round"><line x1="20" y1="8" x2="20" y2="2"/><line x1="20" y1="32" x2="20" y2="38"/><line x1="32" y1="20" x2="38" y2="20"/><line x1="8" y1="20" x2="2" y2="20"/><line x1="28.49" y1="11.51" x2="32.73" y2="7.27"/><line x1="28.49" y1="28.49" x2="32.73" y2="32.73"/><line x1="11.51" y1="28.49" x2="7.27" y2="32.73"/><line x1="11.51" y1="11.51" x2="7.27" y2="7.27"/></g></svg>{% endcapture %}
{% capture icon_cloud_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><g transform="translate(-2.5,1)" fill="#555555"><rect x="6" y="20" width="28" height="12" rx="6" ry="6"/><circle cx="14" cy="19" r="8"/><circle cx="24" cy="16" r="10"/><circle cx="32" cy="21" r="7"/></g></svg>{% endcapture %}
{% capture icon_rain_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><g transform="translate(-1.5,0.5)"><g fill="#555555"><rect x="7" y="12" width="26" height="10" rx="5" ry="5"/><circle cx="14" cy="12" r="7"/><circle cx="23" cy="9" r="8"/><circle cx="30" cy="13" r="6"/></g><g fill="#000000"><polygon points="12,23 16,28 8,28"/><circle cx="12" cy="31" r="5"/><polygon points="20,26 24,31 16,31"/><circle cx="20" cy="34" r="4"/><polygon points="28,23 32,28 24,28"/><circle cx="28" cy="31" r="5"/></g></g></svg>{% endcapture %}
{% capture icon_partly_16 %}<svg viewBox="0 0 40 40" width="16" height="16" xmlns="http://www.w3.org/2000/svg"><g transform="translate(-0.5,3.5)"><g fill="#AAAAAA"><rect x="2" y="23" width="24" height="10" rx="5" ry="5"/><circle cx="9" cy="22" r="6"/><circle cx="17" cy="19" r="8"/><circle cx="24" cy="23" r="5"/></g><circle cx="30" cy="11" r="6" fill="#000000"/><g stroke="#000000" stroke-width="3" stroke-linecap="round"><line x1="30" y1="3" x2="30" y2="0"/><line x1="34.5" y1="6.5" x2="36.5" y2="4.5"/><line x1="37" y1="11" x2="39" y2="11"/></g></g></svg>{% endcapture %}

<div class="page bg--gray-55">
  {% comment %} Date header {% endcomment %}
  <div class="panel date-panel">
    <div class="date-content">
      <div class="day-name">{{ meta.reference_date | date: "%A" }}</div>
      <div class="date-line">{{ meta.reference_date | date: "%d %B" }}</div>
    </div>
    <div class="synced text--gray-30">Synced {{ meta.generated_at | date: "%H:%M %d/%m" }}</div>
  </div>

  {% comment %} Weather: current left + 3-day forecast right {% endcomment %}
  <div class="panel weather-panel">
    <div class="weather-layout">
      {% comment %} Left: current weather (~40%) {% endcomment %}
      <div class="weather-current">
        <div class="weather-current-main">
          <div class="weather-icon">
            {% if weather.icon == "sun" %}{{ icon_sun_32 }}{% elsif weather.icon == "cloud" %}{{ icon_cloud_32 }}{% elsif weather.icon == "rain" %}{{ icon_rain_32 }}{% else %}{{ icon_partly_32 }}{% endif %}
          </div>
          <div class="weather-temperature">{{ weather.temperature }}&deg;C</div>
          <div class="weather-feels-like">
            <div class="weather-feels-like-label text--gray-30">real feel</div>
            <div class="weather-feels-like-value">{{ weather.feels_like }}&deg;C</div>
          </div>
        </div>
        <div class="weather-description">{{ weather.description }}</div>
        {% if weather.alert %}
          <div class="weather-alert">{{ weather.alert }}</div>
        {% endif %}
      </div>
      {% comment %} Right: 5-day forecast, today first (~58%) {% endcomment %}
      <div class="weather-forecast">
        {% for day in weather.forecast limit: 5 %}
          <div class="weather-forecast-day">
            <div class="weather-forecast-day-name">{% if day.date == meta.reference_date %}Today{% else %}{{ day.date | date: "%a" }}{% endif %}</div>
            <div class="weather-forecast-icon">
              {% if day.icon == "sun" %}{{ icon_sun_32 }}{% elsif day.icon == "cloud" %}{{ icon_cloud_32 }}{% elsif day.icon == "rain" %}{{ icon_rain_32 }}{% else %}{{ icon_partly_32 }}{% endif %}
            </div>
            <div class="weather-forecast-temp">{{ day.temperature_high }}&deg;/{{ day.temperature_low }}&deg;</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% comment %} Upcoming events {% endcomment %}
  <div class="panel upcoming-panel">
    <div class="panel-body">
      <div class="section-title section-title--bold">
        Upcoming
      </div>
      <div class="section-body">
        {% if errors.events %}
        <div class="error-title">(!) Not loaded</div>
        <div class="error-detail">{{ errors.events }}</div>
        {% else %}
        {% for event in events limit: 9 %}
          {% assign event_date = event.start | slice: 0, 10 %}
          <div class="event-row">
            <div class="event-time">
              {% if event.all_day %}
                {% if event_date == meta.reference_date %}
                  Today &middot; All day
                {% elsif event.end and event.end != event.start %}
                  {{ event.start | date: "%a %d %b" }}&ndash;{{ event.end | date: "%a %d %b" }}
                {% else %}
                  {{ event.start | date: "%a %d %b" }} &middot; All day
                {% endif %}
              {% else %}
                {% if event_date == meta.reference_date %}
                  Today {{ event.start | date: "%H:%M" }}
                {% else %}
                  {{ event.start | date: "%a %d %b" }} {{ event.start | date: "%H:%M" }}
                {% endif %}
              {% endif %}
            </div>
            <div class="event-title">
              {{ event.title }}
            </div>
          </div>
        {% else %}
          <div class="empty-message">No upcoming events</div>
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Tasks {% endcomment %}
  <div class="panel tasks-panel">
    {% assign due_count = 0 %}
    {% for task in tasks %}
      {% unless task.done %}
        {% if task.due_date and task.due_date <= meta.reference_date %}
          {% assign due_count = due_count | plus: 1 %}
        {% endif %}
      {% endunless %}
    {% endfor %}
    <div class="panel-body">
      <div class="section-title">
        <span class="section-title-label">Tasks</span>{% if due_count > 0 %} - {{ due_count }} due (!){% endif %}
      </div>
      <div class="section-body">
        {% if errors.tasks %}
        <div class="error-title">(!) Not loaded</div>
        <div class="error-detail">{{ errors.tasks }}</div>
        {% else %}
        {% for task in tasks limit: 9 %}
          {% assign is_due = false %}
          {% unless task.done %}
            {% if task.due_date and task.due_date <= meta.reference_date %}
              {% assign is_due = true %}
            {% endif %}
          {% endunless %}
          <div class="task-row">
            <div class="task-checkbox">
              {% if task.done %}
                <div class="task-checkbox-mark"></div>
              {% endif %}
            </div>
            <div class="task-title{% if is_due %} task-title--due{% endif %}">
              {{ task.title }}{% if is_due %} (!){% endif %}
            </div>
          </div>
        {% else %}
          <div class="empty-message">No tasks</div>
        {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>

  {% comment %} Anniversaries: 3 equal columns — title + 2 columns of 4 {% endcomment %}
  <div class="panel anniv-panel">
    <div class="anniv-inner">
      <div class="anniv-title-col">
        <div class="anniv-title">Anniversaries</div>
      </div>
      {% if errors.birthdays %}
        <div class="anniv-status-col">
          <div class="error-title">(!) Not loaded</div>
          <div class="error-detail-small text--gray-30">{{ errors.birthdays }}</div>
        </div>
      {% elsif birthdays.size == 0 %}
        <div class="anniv-status-col">
          <div class="empty-message text--gray-30">No upcoming dates</div>
        </div>
      {% else %}
        <div class="anniv-col">
          {% for entry in birthdays limit: 4 %}
            <div class="anniv-row">
              <span class="anniv-name">{{ entry.name }}</span>
              <span class="anniv-date text--gray-30">
                {% if entry.date == meta.reference_date %}
                  Today!
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
        <div class="anniv-col">
          {% for entry in birthdays offset: 4 limit: 4 %}
            <div class="anniv-row">
              <span class="anniv-name">{{ entry.name }}</span>
              <span class="anniv-date text--gray-30">
                {% if entry.date == meta.reference_date %}
                  Today!
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
