{% comment %}
  devices/x_creative_light.liquid — TRMNL X (1872x1404) creative dashboard layout, light variant.

  Scales the OG creative-light mosaic to the larger TRMNL X canvas:
    * Top-left light panel: day + date + synced time.
    * Top-right light panel: current weather + alert + 3-day forecast.
    * Middle-left light panel: Upcoming calendar events (maximized).
    * Middle-right light panel: Tasks (maximized).
    * Bottom full-width light panel: Anniversaries as a horizontal ticker.

  Uses only the four-level grayscale palette: #000000, #555555, #AAAAAA, #FFFFFF.
  #555555 is used only for borders and text, never as a panel fill.
  Top-level render context: meta, weather, events, tasks, birthdays, errors.
{% endcomment %}
<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>TRMNL X Dashboard — Creative Light</title>
<style>
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Regular.ttf") format("truetype");
    font-weight: normal;
  }
  @font-face {
    font-family: "TRMNL16";
    src: url("../../assets/TRMNL16-Bold.ttf") format("truetype");
    font-weight: bold;
  }
  @font-face {
    font-family: "TRMNL21";
    src: url("../../assets/TRMNL21-Bold.ttf") format("truetype");
    font-weight: bold;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    width: 1872px;
    height: 1404px;
    background: #AAAAAA;
    font-family: "TRMNL16", Arial, Helvetica, sans-serif;
    color: #000000;
    overflow: hidden;
  }

  .page {
    position: relative;
    width: 1872px;
    height: 1404px;
    padding: 24px;
  }

  .panel {
    position: absolute;
    overflow: hidden;
    background: #FFFFFF;
    border: 2px solid #555555;
  }

  /* Top row: date (1/3) + weather (2/3) */
  .date-panel {
    left: 24px;
    top: 24px;
    width: 592px;
    height: 180px;
  }

  .weather-panel {
    left: 664px;
    top: 24px;
    width: 1184px;
    height: 180px;
  }

  /* Middle row */
  .upcoming-panel {
    left: 24px;
    top: 228px;
    width: 1098px;
    height: 678px;
  }

  .tasks-panel {
    left: 1146px;
    top: 228px;
    width: 702px;
    height: 678px;
  }

  /* Bottom row */
  .anniv-panel {
    left: 24px;
    top: 930px;
    width: 1824px;
    height: 450px;
  }

  .day-name {
    font-family: "TRMNL21", "TRMNL16", Arial, sans-serif;
    font-weight: bold;
    font-size: 64px;
    line-height: 1.05;
    color: #000000;
  }

  .date-line {
    font-size: 36px;
    line-height: 1.1;
    margin-top: 6px;
    color: #000000;
  }

  .synced {
    position: absolute;
    right: 24px;
    bottom: 12px;
    font-size: 24px;
    color: #555555;
  }
</style>
</head>
<body>

{% capture icon_sun_64 %}<svg viewBox="0 0 40 40" width="64" height="64" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="20" y1="1" x2="20" y2="7"/><line x1="20" y1="33" x2="20" y2="39"/><line x1="1" y1="20" x2="7" y2="20"/><line x1="33" y1="20" x2="39" y2="20"/><line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/><line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/><line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/><line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/></g></svg>{% endcapture %}
{% capture icon_cloud_64 %}<svg viewBox="0 0 40 40" width="64" height="64" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="24" rx="9" ry="7"/><ellipse cx="24" cy="22" rx="10" ry="8"/><ellipse cx="20" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_rain_64 %}<svg viewBox="0 0 40 40" width="64" height="64" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="16" rx="8" ry="6"/><ellipse cx="23" cy="14" rx="9" ry="7"/><ellipse cx="19" cy="19" rx="11" ry="5"/></g><g stroke="#000000" stroke-width="2"><line x1="13" y1="28" x2="11" y2="36"/><line x1="20" y1="28" x2="18" y2="36"/><line x1="27" y1="28" x2="25" y2="36"/></g></svg>{% endcapture %}
{% capture icon_partly_64 %}<svg viewBox="0 0 40 40" width="64" height="64" xmlns="http://www.w3.org/2000/svg"><circle cx="26" cy="14" r="7" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="26" y1="2" x2="26" y2="5"/><line x1="35" y1="14" x2="38" y2="14"/><line x1="32.5" y1="7.5" x2="34.5" y2="5.5"/></g><g fill="#ffffff" stroke="#000000" stroke-width="2"><ellipse cx="13" cy="24" rx="9" ry="7"/><ellipse cx="22" cy="22" rx="10" ry="8"/><ellipse cx="18" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_sun_80 %}<svg viewBox="0 0 40 40" width="80" height="80" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="20" y1="1" x2="20" y2="7"/><line x1="20" y1="33" x2="20" y2="39"/><line x1="1" y1="20" x2="7" y2="20"/><line x1="33" y1="20" x2="39" y2="20"/><line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/><line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/><line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/><line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/></g></svg>{% endcapture %}
{% capture icon_cloud_80 %}<svg viewBox="0 0 40 40" width="80" height="80" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="24" rx="9" ry="7"/><ellipse cx="24" cy="22" rx="10" ry="8"/><ellipse cx="20" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_rain_80 %}<svg viewBox="0 0 40 40" width="80" height="80" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="16" rx="8" ry="6"/><ellipse cx="23" cy="14" rx="9" ry="7"/><ellipse cx="19" cy="19" rx="11" ry="5"/></g><g stroke="#000000" stroke-width="2"><line x1="13" y1="28" x2="11" y2="36"/><line x1="20" y1="28" x2="18" y2="36"/><line x1="27" y1="28" x2="25" y2="36"/></g></svg>{% endcapture %}
{% capture icon_partly_80 %}<svg viewBox="0 0 40 40" width="80" height="80" xmlns="http://www.w3.org/2000/svg"><circle cx="26" cy="14" r="7" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="26" y1="2" x2="26" y2="5"/><line x1="35" y1="14" x2="38" y2="14"/><line x1="32.5" y1="7.5" x2="34.5" y2="5.5"/></g><g fill="#ffffff" stroke="#000000" stroke-width="2"><ellipse cx="13" cy="24" rx="9" ry="7"/><ellipse cx="22" cy="22" rx="10" ry="8"/><ellipse cx="18" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_sun_40 %}<svg viewBox="0 0 40 40" width="40" height="40" xmlns="http://www.w3.org/2000/svg"><circle cx="20" cy="20" r="9" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="20" y1="1" x2="20" y2="7"/><line x1="20" y1="33" x2="20" y2="39"/><line x1="1" y1="20" x2="7" y2="20"/><line x1="33" y1="20" x2="39" y2="20"/><line x1="6.34" y1="6.34" x2="10.6" y2="10.6"/><line x1="29.4" y1="29.4" x2="33.66" y2="33.66"/><line x1="6.34" y1="33.66" x2="10.6" y2="29.4"/><line x1="29.4" y1="10.6" x2="33.66" y2="6.34"/></g></svg>{% endcapture %}
{% capture icon_cloud_40 %}<svg viewBox="0 0 40 40" width="40" height="40" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="24" rx="9" ry="7"/><ellipse cx="24" cy="22" rx="10" ry="8"/><ellipse cx="20" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}
{% capture icon_rain_40 %}<svg viewBox="0 0 40 40" width="40" height="40" xmlns="http://www.w3.org/2000/svg"><g fill="none" stroke="#000000" stroke-width="2"><ellipse cx="14" cy="16" rx="8" ry="6"/><ellipse cx="23" cy="14" rx="9" ry="7"/><ellipse cx="19" cy="19" rx="11" ry="5"/></g><g stroke="#000000" stroke-width="2"><line x1="13" y1="28" x2="11" y2="36"/><line x1="20" y1="28" x2="18" y2="36"/><line x1="27" y1="28" x2="25" y2="36"/></g></svg>{% endcapture %}
{% capture icon_partly_40 %}<svg viewBox="0 0 40 40" width="40" height="40" xmlns="http://www.w3.org/2000/svg"><circle cx="26" cy="14" r="7" fill="none" stroke="#000000" stroke-width="2"/><g stroke="#000000" stroke-width="2"><line x1="26" y1="2" x2="26" y2="5"/><line x1="35" y1="14" x2="38" y2="14"/><line x1="32.5" y1="7.5" x2="34.5" y2="5.5"/></g><g fill="#ffffff" stroke="#000000" stroke-width="2"><ellipse cx="13" cy="24" rx="9" ry="7"/><ellipse cx="22" cy="22" rx="10" ry="8"/><ellipse cx="18" cy="27" rx="12" ry="6"/></g></svg>{% endcapture %}

<div class="page">
  {% comment %} Date header {% endcomment %}
  <div class="panel date-panel">
    <div style="display:flex; flex-direction:column; justify-content:center; height:100%; padding:24px;">
      <div class="day-name">{{ meta.reference_date | date: "%A" }}</div>
      <div class="date-line">{{ meta.reference_date | date: "%d %B" }}</div>
    </div>
    <div class="synced">Synced {{ meta.generated_at | date: "%H:%M %d/%m" }}</div>
  </div>

  {% comment %} Weather: current left + larger 3-day forecast right {% endcomment %}
  <div class="panel weather-panel">
    <div style="height:100%; padding:20px; box-sizing:border-box; display:flex; gap:16px;">
      {% comment %} Left: current weather (~25%) {% endcomment %}
      <div style="flex:0 0 25%; display:flex; flex-direction:column; justify-content:center;">
        <div style="display:flex; align-items:center; gap:16px; margin-bottom:8px;">
          <div style="width:64px; height:64px; flex:0 0 auto;">
            {% if weather.icon == "sun" %}{{ icon_sun_64 }}{% elsif weather.icon == "cloud" %}{{ icon_cloud_64 }}{% elsif weather.icon == "rain" %}{{ icon_rain_64 }}{% else %}{{ icon_partly_64 }}{% endif %}
          </div>
          <div style="font-weight:bold; font-size:56px; line-height:1; color:#000000;">{{ weather.temperature }}&deg;C</div>
          <div style="display:flex; flex-direction:column; line-height:1; margin-left:8px;">
            <div style="font-size:16px; color:#555555; text-transform:lowercase;">real feel</div>
            <div style="font-size:22px; color:#000000;">{{ weather.feels_like }}&deg;C</div>
          </div>
        </div>
        <div style="font-size:22px; line-height:1.3; color:#000000; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ weather.description }}</div>
        {% if weather.alert %}
          <div style="font-size:22px; line-height:1.3; color:#000000; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-top:4px;">{{ weather.alert }}</div>
        {% endif %}
      </div>
      {% comment %} Right: larger 3-day forecast (~75%) {% endcomment %}
      <div style="flex:0 0 75%; display:flex; gap:16px;">
        {% for day in weather.forecast limit: 3 %}
          <div style="flex:1 1 0; min-width:0; text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center;">
            <div style="font-size:32px; line-height:1.2; color:#000000; white-space:nowrap;">{{ day.date | date: "%a" }}</div>
            <div style="width:80px; height:80px; margin:8px 0;">
              {% if day.icon == "sun" %}{{ icon_sun_80 }}{% elsif day.icon == "cloud" %}{{ icon_cloud_80 }}{% elsif day.icon == "rain" %}{{ icon_rain_80 }}{% else %}{{ icon_partly_80 }}{% endif %}
            </div>
            <div style="font-size:32px; line-height:1.2; color:#000000;">{{ day.temperature_high }}&deg;/{{ day.temperature_low }}&deg;</div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% comment %} Upcoming events {% endcomment %}
  <div class="panel upcoming-panel">
    {% render 'partials/calendar', events: events, error: errors.events, today: meta.reference_date,
       max_events: 17, font_size_medium: 34, font_size_small: 28,
       line_height: 34, padding: 20 %}
  </div>

  {% comment %} Tasks {% endcomment %}
  <div class="panel tasks-panel">
    {% render 'partials/tasks', tasks: tasks, error: errors.tasks, today: meta.reference_date,
       max_tasks: 17, checkbox_size: 24, font_size_medium: 34,
       font_size_small: 28, line_height: 34, padding: 20 %}
  </div>

  {% comment %} Anniversaries: 3 equal columns — title + 2 columns of 4 {% endcomment %}
  <div class="panel anniv-panel">
    <div style="padding:24px; height:100%; box-sizing:border-box; display:flex; gap:24px;">
      <div style="flex:1 1 0;">
        <div style="font-weight:bold; font-size:34px; color:#000000; line-height:1;">Anniversaries</div>
      </div>
      {% if errors.birthdays %}
        <div style="flex:2 1 0;">
          <div style="font-size:30px; font-weight:bold; color:#000000;">(!) Not loaded</div>
          <div style="font-size:24px; color:#555555; margin-top:12px;">{{ errors.birthdays }}</div>
        </div>
      {% elsif birthdays.size == 0 %}
        <div style="flex:2 1 0;">
          <div style="font-size:30px; color:#555555;">No upcoming dates</div>
        </div>
      {% else %}
        <div style="flex:1 1 0; overflow:hidden;">
          {% for entry in birthdays limit: 4 %}
            <div style="display:flex; align-items:baseline; gap:10px; font-size:28px; line-height:34px; color:#000000; white-space:nowrap; overflow:hidden;">
              <span style="font-weight:bold; overflow:hidden; text-overflow:ellipsis;">{{ entry.name }}</span>
              <span style="color:#555555; flex:0 0 auto;">
                {% if entry.date == meta.reference_date %}
                  Today!
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
        <div style="flex:1 1 0; overflow:hidden;">
          {% for entry in birthdays offset: 4 limit: 4 %}
            <div style="display:flex; align-items:baseline; gap:10px; font-size:28px; line-height:34px; color:#000000; white-space:nowrap; overflow:hidden;">
              <span style="font-weight:bold; overflow:hidden; text-overflow:ellipsis;">{{ entry.name }}</span>
              <span style="color:#555555; flex:0 0 auto;">
                {% if entry.date == meta.reference_date %}
                  Today!
                {% else %}
                  {{ entry.date | date: "%a %d %b" }}
                {% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
</body>
</html>
