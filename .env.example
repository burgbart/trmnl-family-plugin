# Weather (defaults to Amsterdam if not set)
WEATHER_LATITUDE=52.3676
WEATHER_LONGITUDE=4.9041
CITY=Amsterdam

# Optional Open-Meteo forecast model. Leave unset to use Open-Meteo's default
# best_match selection. For Europe, try icon_seamless (DWD, higher resolution);
# for global coverage, try gfs_seamless (NOAA GFS).
WEATHER_MODEL=

# Local timezone for calendar event times (e.g. Europe/Amsterdam, America/New_York).
# Defaults to Europe/Amsterdam to match the default weather location.
TIMEZONE=Europe/Amsterdam

# Google Calendar service account
# Either the path to the JSON key file, or the raw JSON contents.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Comma-separated list of calendar IDs.
GOOGLE_CALENDAR_IDS=
# Optional: only show events with one of these attendee emails (comma-separated).
CALENDAR_ATTENDEE_EMAILS=
# Optional: show all events from this calendar ID regardless of attendees.
CALENDAR_MAIN_CALENDAR_ID=

# TickTick Developer API
TICKTICK_ACCESS_TOKEN=
TICKTICK_LIST_ID=

# Optional: render as if today were this date (DD-MM-YYYY). Useful for testing.
REFERENCE_DATE=

# Optional: OG device grayscale level, used by export_preview.py's CSS
# approximation. Default 4 (softer look, matching the original Pillow-rendered
# dashboard.png). Set to 2 for a harsher 1-bit hard-contrast approximation.
OG_GRAYSCALE_LEVELS=4

# Terminal dashboard sources (optional; falls back to the sources above).
# Comma-separated list of calendar IDs / TickTick list IDs to switch between.
TERMINAL_CALENDAR_IDS=
TERMINAL_TICKTICK_LIST_IDS=

# Cloudflare R2 upload (Phase 5 — GitHub Actions variant).
# Only needed when uploading the generated PNG from GitHub Actions.
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
# Public base URL for the bucket (custom domain or r2.dev), used to print the URL.
# The dashboard JSON is assumed to live at <CLOUDFLARE_R2_PUBLIC_URL>/dashboard-v2.json
# unless DASHBOARD_JSON_URL is set explicitly.
CLOUDFLARE_R2_PUBLIC_URL=

# URL or local path to the unified dashboard JSON.
# Defaults to <CLOUDFLARE_R2_PUBLIC_URL>/dashboard-v2.json or output/dashboard-v2.json.
DASHBOARD_JSON_URL=

# Server variant settings (Phase 6 — long-running server mode).
# Seconds between automatic data/PNG refreshes. Default is 60 (1 minute).
REFRESH_INTERVAL_SECONDS=60
# HTTP port when serving the latest PNG. Default is 8080.
SERVER_PORT=8080
# Device to generate in server mode: og, x, or both.
SERVER_DEVICE=both
